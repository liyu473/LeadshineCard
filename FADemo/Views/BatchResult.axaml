<w:AppWindow
    x:Class="FADemo.Views.BatchResult"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FADemo.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:FluentAvalonia.UI.Controls"
    xmlns:vm="using:FADemo.ViewModels"
    xmlns:w="using:FluentAvalonia.UI.Windowing"
    Title="批量检测结果"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:BatchResultViewModel"
    Background="{x:Null}"
    TransparencyLevelHint="AcrylicBlur"
    mc:Ignorable="d">
    <w:AppWindow.Resources>
        <converters:MatToBitmapConverter x:Key="MatToBitmapConverter" />
    </w:AppWindow.Resources>
    <ScrollViewer Margin="0,40" Padding="{StaticResource PageMargin}">
        <ListBox Name="ImagesListBox" ItemsSource="{Binding Results}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Background="Transparent">
                        <Panel>
                            <Image
                                Height="100"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Source="{Binding ., Converter={StaticResource MatToBitmapConverter}}"
                                Stretch="Uniform" />

                            <ui:CommandBarButton
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Command="{Binding #ImagesListBox.((vm:BatchResultViewModel)DataContext).ShowResultsCommand}"
                                CommandParameter="{Binding RelativeSource={RelativeSource Self}, Path=DataContext}"
                                IconSource="FullScreen" />
                        </Panel>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </ScrollViewer>
</w:AppWindow>
