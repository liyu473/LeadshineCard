<ui:AppWindow
    x:Class="FADemo.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:control="using:FluentAvalonia.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:FluentAvalonia.UI.Windowing"
    xmlns:vm="using:FADemo.ViewModels"
    Title="FADemo"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainWindowViewModel"
    Background="{x:Null}"
    TransparencyLevelHint="Mica"
    mc:Ignorable="d">
    <Grid>
        <ContentPresenter x:Name="RootHost" />
        <Border Background="#80000000" IsVisible="{Binding IsLoading}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <control:ProgressRing
                    Width="80"
                    Height="80"
                    IsIndeterminate="True" />
                <TextBlock
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Text="请等候" />
            </StackPanel>
        </Border>
    </Grid>
</ui:AppWindow>
