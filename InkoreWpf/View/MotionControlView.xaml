<UserControl
    x:Class="InkoreWpf.View.MotionControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctrl="clr-namespace:InkoreWpf.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InkoreWpf.View"
    xmlns:lyu="http://schemas.lyuwpfhelper.com/winfx/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.inkore.net/lib/ui/wpf/modern"
    xmlns:viewmodel="clr-namespace:InkoreWpf.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:MotionControlViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,Auto,*">
        <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="16">
            <Button Content="初始化" />
            <Button Content="复位" />
            <ComboBox
                ui:ControlHelper.PlaceholderText="初始化卡列表"
                DisplayMemberPath="CardNo"
                ItemsSource="{Binding MotionCards}"
                SelectedItem="{Binding SelectedCard}" />
        </lyu:SimpleStackPanel>
        <TabControl
            Grid.Row="2"
            Margin="0,12,0,0"
            lyu:TabControlTransitionHelper.TransitionMode="Right2LeftWithFade"
            Style="{StaticResource TabControlPivotStyle}">
            <TabItem Header="运动控制">
                <Grid Margin="0,8,0,0">
                    <ComboBox
                        ui:ControlHelper.PlaceholderText="轴列表"
                        ItemsSource="{Binding AxisSource}"
                        SelectedItem="{Binding SelectedAxis}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ., Converter={StaticResource AxisToNameConverter}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </Grid>
            </TabItem>
            <TabItem Header="IO控制">
                <Grid Margin="0,8,0,0" ColumnDefinitions="*,*">
                    <Grid Grid.Column="0" RowDefinitions="Auto,*">
                        <ctrl:SectionHeader Title="输入" Grid.Row="0" />
                    </Grid>
                    <Grid Grid.Column="1" RowDefinitions="Auto,*">
                        <ctrl:SectionHeader Title="输出" Grid.Row="0" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
