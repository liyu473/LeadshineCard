<UserControl
    x:Class="InkoreWpf.View.MotionControlView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:InkoreWpf.View"
    xmlns:lyu="http://schemas.lyuwpfhelper.com/winfx/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewmodel="clr-namespace:InkoreWpf.ViewModel"
    d:DataContext="{d:DesignInstance Type=viewmodel:MotionControlViewModel}"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid RowDefinitions="Auto,*">
        <lyu:SimpleStackPanel Orientation="Horizontal" Spacing="12">
            <Button Content="初始化" />
        </lyu:SimpleStackPanel>
    </Grid>
</UserControl>
